<VirtualHost *:80>
    ServerName www.{{ item.name }}.com
    ServerAlias {{ item.name }}.com
    DocumentRoot /var/www/{{ item.name }}

    <Directory /var/www/{{ item.name }}>
        AllowOverride All
        Require all granted
    </Directory>

    ErrorLog ${APACHE_LOG_DIR}/{{ item.name }}_error.log
    CustomLog ${APACHE_LOG_DIR}/{{ item.name }}_access.log combined
</VirtualHost>
